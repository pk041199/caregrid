{
  "id": "diet_recall_24h",
  "title": "24-Hour Diet Recall (Individual Agenda)",
  "version": 2,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 30,
    "cycleOptionsDays": [7, 14, 30, 60]
  },
  "sections": [
    {
      "id": "meal_timeline",
      "title": "1. Meal Timeline (Last 24 Hours)",
      "fields": [
        { "id": "early_morning", "label": "Early Morning Intake", "type": "textarea", "required": false },
        { "id": "breakfast", "label": "Breakfast", "type": "textarea", "required": false },
        { "id": "mid_morning", "label": "Mid-Morning", "type": "textarea", "required": false },
        { "id": "lunch", "label": "Lunch", "type": "textarea", "required": false },
        { "id": "evening_snacks", "label": "Evening Snacks", "type": "textarea", "required": false },
        { "id": "dinner", "label": "Dinner", "type": "textarea", "required": false },
        { "id": "late_night", "label": "Late-Night Intake", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "intake_quality",
      "title": "2. Intake Quality",
      "fields": [
        { "id": "fruits_veg_servings", "label": "Fruits/Vegetables Servings", "type": "number", "required": false, "validation": { "min": 0, "max": 20 } },
        { "id": "protein_sources", "label": "Protein Sources Taken", "type": "textarea", "required": false },
        { "id": "outside_food", "label": "Outside/Junk Food Taken", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "sugary_drinks", "label": "Sugary Drinks Taken", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "water_glasses", "label": "Water (glasses/day)", "type": "number", "required": false, "validation": { "min": 0, "max": 30 } }
      ]
    },
    {
      "id": "nutrition_advice",
      "title": "3. Nutrition Advice and Follow-up",
      "fields": [
        { "id": "key_diet_gap", "label": "Key Diet Gap Identified", "type": "textarea", "required": false },
        { "id": "advice_given", "label": "Advice Given", "type": "textarea", "required": false },
        { "id": "next_review_date", "label": "Next Review Date", "type": "date", "required": false }
      ]
    }
  ]
}
