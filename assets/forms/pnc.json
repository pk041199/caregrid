{
  "id": "pnc",
  "title": "PNC Main Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 14,
    "cycleOptionsDays": [7, 14, 28, 42]
  },
  "sections": [
    {
      "id": "delivery_context",
      "title": "1. Delivery and Postnatal Context",
      "fields": [
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true },
        { "id": "delivery_date", "label": "Delivery Date", "type": "date", "required": false },
        { "id": "delivery_type", "label": "Type of Delivery", "type": "select", "required": false, "options": ["Normal Vaginal Delivery", "LSCS", "Assisted", "Other"] },
        { "id": "postnatal_day", "label": "Postnatal Day", "type": "number", "required": false }
      ]
    },
    {
      "id": "maternal_status",
      "title": "2. Maternal Status",
      "fields": [
        { "id": "mother_complaints", "label": "Mother Complaints", "type": "textarea", "required": false },
        { "id": "bleeding", "label": "Abnormal Bleeding", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "fever", "label": "Fever", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "breastfeeding_issues", "label": "Breastfeeding Issues", "type": "textarea", "required": false },
        { "id": "mother_examination", "label": "Mother Examination", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "baby_and_plan",
      "title": "3. Baby and Follow-up Plan",
      "fields": [
        { "id": "baby_status", "label": "Baby Status", "type": "textarea", "required": false },
        { "id": "contraception_counselling", "label": "Contraception Counselling", "type": "textarea", "required": false },
        { "id": "advice", "label": "Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
