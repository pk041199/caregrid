{
  "id": "environmental_history_family",
  "title": "Family Environmental Risk Assessment",
  "version": 2,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 180,
    "cycleOptionsDays": [90, 180, 365]
  },
  "sections": [
    {
      "id": "housing_crowding",
      "title": "1. Housing and Crowding",
      "fields": [
        { "id": "house_type", "label": "House Type", "type": "select", "required": false, "options": ["Kutcha", "Semi-pucca", "Pucca"] },
        { "id": "house_ownership", "label": "House Ownership", "type": "select", "required": false, "options": ["Owned", "Rented", "Temporary"] },
        { "id": "no_of_rooms", "label": "Number of Rooms", "type": "number", "required": false, "validation": { "min": 1, "max": 20 } },
        { "id": "overcrowding", "label": "Overcrowding", "type": "select", "required": false, "options": ["Yes", "No", "Unknown"] }
      ]
    },
    {
      "id": "water_sanitation_waste",
      "title": "2. Water, Sanitation, Waste",
      "fields": [
        { "id": "drinking_water_source", "label": "Drinking Water Source", "type": "select", "required": false, "options": ["Piped", "Borewell", "Open well", "Tank", "Other"] },
        { "id": "water_treatment", "label": "Water Treatment at Home", "type": "select", "required": false, "options": ["Boiling", "Filter", "Chlorination", "None"] },
        { "id": "toilet_type", "label": "Toilet Access", "type": "select", "required": false, "options": ["Household", "Community", "Open defecation"] },
        { "id": "solid_waste_disposal", "label": "Solid Waste Disposal", "type": "select", "required": false, "options": ["Door-to-door", "Burning", "Open dumping", "Other"] }
      ]
    },
    {
      "id": "air_vector_risk",
      "title": "3. Air and Vector Risk",
      "fields": [
        { "id": "cooking_fuel", "label": "Primary Cooking Fuel", "type": "select", "required": false, "options": ["LPG", "Electric", "Biomass", "Kerosene", "Other"] },
        { "id": "kitchen_ventilation", "label": "Kitchen Ventilation", "type": "select", "required": false, "options": ["Good", "Average", "Poor"] },
        { "id": "smoking_inside", "label": "Smoking Inside Home", "type": "select", "required": false, "options": ["Yes", "No", "Unknown"] },
        { "id": "mosquito_breeding_risk", "label": "Mosquito Breeding Risk Nearby", "type": "select", "required": false, "options": ["Low", "Moderate", "High"] }
      ]
    },
    {
      "id": "environment_plan",
      "title": "4. Environmental Advice and Plan",
      "fields": [
        { "id": "key_risk_summary", "label": "Key Environmental Risk Summary", "type": "textarea", "required": false },
        { "id": "advice_given", "label": "Advice Given", "type": "textarea", "required": false },
        { "id": "next_review_date", "label": "Next Review Date", "type": "date", "required": false }
      ]
    }
  ]
}
