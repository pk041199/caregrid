{
  "id": "machine_connect_examination",
  "title": "Machine-Connected Examination (ECG/PFT/Steth)",
  "version": 1,
  "followup": { "enabled": false },
  "sections": [
    {
      "id": "devices",
      "title": "Connected Devices",
      "fields": [
        { "id": "ecg_done", "label": "ECG Done", "type": "select", "required": false, "options": ["Yes", "No"] },
        { "id": "pft_done", "label": "PFT Done", "type": "select", "required": false, "options": ["Yes", "No"] },
        { "id": "digital_steth_done", "label": "Digital Steth Audio Captured", "type": "select", "required": false, "options": ["Yes", "No"] }
      ]
    },
    {
      "id": "results",
      "title": "Result Notes",
      "fields": [
        { "id": "ecg_summary", "label": "ECG Summary", "type": "text", "required": false, "showWhen": { "field": "ecg_done", "equals": "Yes" } },
        { "id": "pft_summary", "label": "PFT Summary", "type": "text", "required": false, "showWhen": { "field": "pft_done", "equals": "Yes" } },
        { "id": "audio_summary", "label": "Stethoscope Audio Summary", "type": "text", "required": false, "showWhen": { "field": "digital_steth_done", "equals": "Yes" } },
        { "id": "machine_notes", "label": "Additional Notes", "type": "text", "required": false }
      ]
    }
  ]
}
