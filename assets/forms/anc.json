{
  "id": "anc",
  "title": "ANC Main Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 30,
    "cycleOptionsDays": [14, 30, 60]
  },
  "sections": [
    {
      "id": "anc_booking",
      "title": "1. Booking and Obstetric History",
      "fields": [
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true },
        { "id": "lmp", "label": "LMP", "type": "date", "required": false },
        { "id": "edd", "label": "EDD", "type": "date", "required": false },
        { "id": "gestational_age_weeks", "label": "Gestational Age (weeks)", "type": "number", "required": false },
        { "id": "gravida_para", "label": "Gravida / Para / Living", "type": "text", "required": false },
        { "id": "high_risk_pregnancy", "label": "High Risk Pregnancy", "type": "select", "required": false, "options": ["No", "Yes"] }
      ]
    },
    {
      "id": "anc_history",
      "title": "2. Complaints and History",
      "fields": [
        { "id": "complaints", "label": "Complaints", "type": "textarea", "required": false },
        { "id": "danger_signs", "label": "Danger Signs", "type": "textarea", "required": false },
        { "id": "past_obstetric_history", "label": "Past Obstetric History", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "anc_exam",
      "title": "3. Examination and Investigations",
      "fields": [
        { "id": "weight_kg", "label": "Weight (kg)", "type": "number", "required": false },
        { "id": "bp", "label": "Blood Pressure", "type": "text", "required": false },
        { "id": "pallor", "label": "Pallor", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "pedal_edema", "label": "Pedal Edema", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "fetal_heart_sound", "label": "Fetal Heart Sound", "type": "text", "required": false },
        { "id": "investigations", "label": "Investigations", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "anc_plan",
      "title": "4. Advice and Follow-up",
      "fields": [
        { "id": "supplements", "label": "Supplements Given", "type": "textarea", "required": false },
        { "id": "counselling", "label": "Counselling / Advice", "type": "textarea", "required": false },
        { "id": "diagnosis_text", "label": "Diagnosis / Risk Summary", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
