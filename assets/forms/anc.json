{
  "id": "anc",
  "title": "Antenatal Care (ANC) Agenda-Based Visit",
  "version": 2,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 30,
    "cycleOptionsDays": [14, 30, 60]
  },
  "sections": [
    {
      "id": "mcp_reference",
      "title": "0. MCP Card Reference",
      "showForVisitType": ["First", "Follow-up"],
      "fields": [
        { "id": "mcp_card_available", "label": "MCP Card Available", "type": "select", "required": true, "options": ["Yes", "No"] },
        { "id": "mcp_card_number", "label": "MCP Card Number", "type": "text", "required": false },
        { "id": "mcp_last_updated_on", "label": "Last MCP Entry Date", "type": "date", "required": false }
      ]
    },
    {
      "id": "visit_context",
      "title": "1. Visit Context",
      "showForVisitType": ["First", "Follow-up"],
      "fields": [
        { "id": "visit_type", "label": "Visit Type", "type": "select", "required": true, "options": ["First", "Follow-up"] },
        { "id": "picme_number", "label": "PICME Number", "type": "text", "required": true },
        { "id": "anc_visits_total", "label": "Total ANC Visits Till Date", "type": "number", "required": true }
      ]
    },
    {
      "id": "obstetric_baseline",
      "title": "2. Obstetric Baseline",
      "showForVisitType": ["First"],
      "fields": [
        { "id": "lmp", "label": "LMP", "type": "date", "required": true },
        { "id": "edd", "label": "EDD", "type": "date", "required": false },
        { "id": "gestational_age_weeks", "label": "Gestational Age (weeks)", "type": "number", "required": true },
        { "id": "trimester", "label": "Trimester", "type": "select", "required": false, "options": ["I", "II", "III"] },
        { "id": "gpla", "label": "GPLA", "type": "text", "required": false },
        { "id": "high_risk_baseline", "label": "Baseline High Risk", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "high_risk_details", "label": "High Risk Details", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "current_history",
      "title": "3. Current History and Complaints",
      "showForVisitType": ["Follow-up"],
      "fields": [
        { "id": "presenting_complaints", "label": "Presenting Complaints", "type": "textarea", "required": true },
        { "id": "danger_signs", "label": "Any Danger Signs", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "danger_sign_notes", "label": "Danger Sign Notes", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "exam",
      "title": "4. Clinical Examination",
      "showForVisitType": ["First", "Follow-up"],
      "fields": [
        { "id": "height_cm", "label": "Height (cm)", "type": "number", "required": false, "validation": { "min": 100, "max": 220 } },
        { "id": "weight_kg", "label": "Weight (kg)", "type": "number", "required": true, "validation": { "min": 25, "max": 180 } },
        { "id": "bp", "label": "Blood Pressure", "type": "text", "required": true },
        { "id": "pulse", "label": "Pulse/min", "type": "number", "required": false, "validation": { "min": 30, "max": 220 } },
        { "id": "pallor", "label": "Pallor", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "pedal_edema", "label": "Pedal Edema", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "fundal_height_cm", "label": "Fundal Height (cm)", "type": "number", "required": false },
        { "id": "fhs_status", "label": "FHS", "type": "select", "required": false, "options": ["Heard", "Not heard", "Not assessed"] },
        { "id": "fetal_movements", "label": "Fetal Movements", "type": "select", "required": false, "options": ["Present", "Reduced", "Absent", "Not assessed"] }
      ]
    },
    {
      "id": "investigation_plan",
      "title": "5. Investigations and Supplements",
      "showForVisitType": ["First", "Follow-up"],
      "fields": [
        { "id": "hb", "label": "Hb (g/dL)", "type": "number", "required": true },
        { "id": "urine_albumin_sugar", "label": "Urine Albumin/Sugar", "type": "text", "required": false },
        { "id": "blood_sugar", "label": "Blood Sugar", "type": "text", "required": false },
        { "id": "scan_summary", "label": "Scan Summary", "type": "textarea", "required": false },
        { "id": "ifa_given", "label": "IFA Given", "type": "select", "required": false, "options": ["Yes", "No"] },
        { "id": "calcium_given", "label": "Calcium Given", "type": "select", "required": false, "options": ["Yes", "No"] },
        { "id": "td_status", "label": "Td/TT Status", "type": "text", "required": false }
      ]
    },
    {
      "id": "plan_followup",
      "title": "6. Plan and Follow-up",
      "showForVisitType": ["First", "Follow-up"],
      "fields": [
        { "id": "counseling", "label": "Counseling and Birth Preparedness", "type": "textarea", "required": false },
        { "id": "referral_needed", "label": "Referral Needed", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "next_visit_date", "label": "Next Visit Date", "type": "date", "required": true }
      ]
    }
  ]
}
