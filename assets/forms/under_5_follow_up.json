{
  "id": "under_5_follow_up",
  "title": "Under 5 Follow-up Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 14,
    "cycleOptionsDays": [7, 14, 30]
  },
  "sections": [
    {
      "id": "visit_link",
      "title": "1. Link to Previous Visit",
      "fields": [
        { "id": "linked_visit_reference", "label": "Main / Follow-up visit", "type": "select", "required": false, "options": [], "dynamicOptionsKey": "visitOptions" },
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true }
      ]
    },
    {
      "id": "child_status",
      "title": "2. Child Status Update",
      "fields": [
        { "id": "presenting_complaints", "label": "Current Complaints", "type": "textarea", "required": false },
        { "id": "feeding_status", "label": "Feeding Status", "type": "textarea", "required": false },
        { "id": "danger_signs", "label": "Danger Signs", "type": "textarea", "required": false },
        { "id": "growth_update", "label": "Growth Update", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "child_plan",
      "title": "3. Advice and Follow-up",
      "fields": [
        { "id": "advice", "label": "Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Next Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
