{
  "id": "pnc_follow_up",
  "title": "PNC Follow-up Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 14,
    "cycleOptionsDays": [7, 14, 28, 42]
  },
  "sections": [
    {
      "id": "visit_link",
      "title": "1. Link to Previous Visit",
      "fields": [
        { "id": "linked_visit_reference", "label": "Main / Follow-up visit", "type": "select", "required": false, "options": [], "dynamicOptionsKey": "visitOptions" },
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true }
      ]
    },
    {
      "id": "pnc_status",
      "title": "2. Maternal and Baby Status",
      "fields": [
        { "id": "mother_complaints", "label": "Mother Complaints", "type": "textarea", "required": false },
        { "id": "breastfeeding_issues", "label": "Breastfeeding Issues", "type": "textarea", "required": false },
        { "id": "baby_feeding", "label": "Baby Feeding Status", "type": "textarea", "required": false },
        { "id": "danger_signs", "label": "Danger Signs", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "pnc_plan",
      "title": "3. Advice and Follow-up",
      "fields": [
        { "id": "advice", "label": "Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Next Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
