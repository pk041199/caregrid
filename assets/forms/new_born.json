{
  "id": "new_born",
  "title": "New Born Main Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 7,
    "cycleOptionsDays": [3, 7, 14, 28]
  },
  "sections": [
    {
      "id": "birth_details",
      "title": "1. Birth Details",
      "fields": [
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true },
        { "id": "date_of_birth", "label": "Date of Birth", "type": "date", "required": false },
        { "id": "birth_weight", "label": "Birth Weight", "type": "text", "required": false },
        { "id": "gestation", "label": "Gestation", "type": "text", "required": false }
      ]
    },
    {
      "id": "newborn_status",
      "title": "2. New Born Status",
      "fields": [
        { "id": "feeding_status", "label": "Feeding Status", "type": "textarea", "required": false },
        { "id": "crying_activity", "label": "Crying / Activity", "type": "textarea", "required": false },
        { "id": "temperature", "label": "Temperature", "type": "text", "required": false },
        { "id": "jaundice", "label": "Jaundice", "type": "select", "required": false, "options": ["No", "Yes"] },
        { "id": "danger_signs", "label": "Danger Signs", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "newborn_plan",
      "title": "3. Examination and Advice",
      "fields": [
        { "id": "examination", "label": "Examination", "type": "textarea", "required": false },
        { "id": "immunization", "label": "Immunization Given", "type": "textarea", "required": false },
        { "id": "advice", "label": "Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
