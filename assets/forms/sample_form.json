{
  "id": "routine_health",
  "title": "Routine Health Details",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 90,
    "cycleOptionsDays": [30, 60, 90, 180]
  },
  "sections": [
    {
      "id": "demographic",
      "title": "Demographic Details",
      "fields": [
        {
          "id": "full_name",
          "label": "Full Name",
          "type": "text",
          "required": true,
          "validation": {
            "minLength": 2
          }
        },
        {
          "id": "sex",
          "label": "Sex",
          "type": "select",
          "required": true,
          "options": ["Male", "Female", "Other"]
        },
        {
          "id": "dob",
          "label": "Date of Birth",
          "type": "date",
          "required": true
        },
        {
          "id": "marital_status",
          "label": "Marital Status",
          "type": "select",
          "required": false,
          "options": ["Never Married", "Married", "Widowed", "Divorced/Separated"]
        }
      ]
    },
    {
      "id": "vitals",
      "title": "Vitals",
      "fields": [
        {
          "id": "height_cm",
          "label": "Height (cm)",
          "type": "number",
          "required": false,
          "validation": { "min": 30, "max": 250 }
        },
        {
          "id": "weight_kg",
          "label": "Weight (kg)",
          "type": "number",
          "required": false,
          "validation": { "min": 2, "max": 300 }
        },
        {
          "id": "bp_systolic",
          "label": "BP Systolic",
          "type": "number",
          "required": false,
          "validation": { "min": 60, "max": 260 }
        },
        {
          "id": "bp_diastolic",
          "label": "BP Diastolic",
          "type": "number",
          "required": false,
          "validation": { "min": 30, "max": 160 }
        },
        {
          "id": "random_sugar",
          "label": "Random Blood Sugar (mg/dL)",
          "type": "number",
          "required": false,
          "validation": { "min": 40, "max": 600 }
        }
      ]
    }
  ],
  "suggestedForms": [
    {
      "id": "ncd",
      "title": "NCD Screening",
      "when": {
        "any": [
          { "field": "bp_systolic", "gte": 140 },
          { "field": "bp_diastolic", "gte": 90 },
          { "field": "random_sugar", "gte": 200 }
        ]
      },
      "followupCycleDays": 90
    }
  ]
}
