{
  "id": "smoking_history",
  "title": "Smoking History",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 90,
    "cycleOptionsDays": [30, 60, 90]
  },
  "sections": [
    {
      "id": "tobacco_profile",
      "title": "Tobacco Profile",
      "fields": [
        { "id": "current_use", "label": "Current Tobacco Use (write Yes/No/Past with details)", "type": "text", "required": false },
        { "id": "type_of_use", "label": "Type (smoking/smokeless/mixed + brand if known)", "type": "text", "required": false },
        { "id": "years_of_use", "label": "Years of Use (approx)", "type": "text", "required": false },
        { "id": "quantity_per_day", "label": "Quantity Per Day / Week", "type": "text", "required": false }
      ]
    },
    {
      "id": "cessation_support",
      "title": "Cessation Support",
      "fields": [
        { "id": "willing_to_quit", "label": "Willing to Quit (Yes/No/Not sure + reason)", "type": "text", "required": false },
        { "id": "counselling_given", "label": "Counselling Given (what was advised)", "type": "textarea", "required": false },
        { "id": "next_follow_up_date", "label": "Next Follow-up Date", "type": "date", "required": false },
        { "id": "notes", "label": "Additional Notes", "type": "textarea", "required": false }
      ]
    }
  ]
}
