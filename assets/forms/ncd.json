{
  "id": "ncd",
  "title": "NCD Main Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 90,
    "cycleOptionsDays": [30, 60, 90, 180]
  },
  "sections": [
    {
      "id": "ncd_profile",
      "title": "1. NCD Profile",
      "fields": [
        { "id": "ncd_type", "label": "NCD Type", "type": "select", "required": true, "options": ["Hypertension", "Diabetes", "CKD", "COPD", "Asthma", "Stroke", "Heart Disease", "Cancer", "Other"] },
        { "id": "risk_factors", "label": "Risk Factors", "type": "textarea", "required": false },
        { "id": "family_history_ncd", "label": "Family History", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "ncd_history",
      "title": "2. Symptoms and History",
      "fields": [
        { "id": "symptom_history", "label": "Symptom History", "type": "textarea", "required": false },
        { "id": "duration_of_disease", "label": "Duration of Disease", "type": "text", "required": false },
        { "id": "drug_history", "label": "Drug History", "type": "textarea", "required": false },
        { "id": "adherence", "label": "Adherence", "type": "select", "required": false, "options": ["Good", "Partial", "Poor", "Not on treatment"] }
      ]
    },
    {
      "id": "ncd_examination",
      "title": "3. Examination and Measurements",
      "fields": [
        { "id": "weight_kg", "label": "Weight (kg)", "type": "number", "required": false },
        { "id": "height_cm", "label": "Height (cm)", "type": "number", "required": false },
        { "id": "bp", "label": "Blood Pressure", "type": "text", "required": false },
        { "id": "blood_sugar", "label": "Blood Sugar", "type": "text", "required": false },
        { "id": "systemic_findings", "label": "Systemic Findings", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "ncd_plan",
      "title": "4. Diagnosis and Plan",
      "fields": [
        { "id": "diagnosis_text", "label": "Diagnosis", "type": "textarea", "required": true },
        { "id": "icd10_code", "label": "ICD-10 Code", "type": "text", "required": false },
        { "id": "investigations", "label": "Investigations", "type": "textarea", "required": false },
        { "id": "rx_treatment", "label": "Rx / Treatment", "type": "textarea", "required": true },
        { "id": "lifestyle_advice", "label": "Lifestyle Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
