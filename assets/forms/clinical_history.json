{
  "id": "clinical_history",
  "title": "Detailed Clinical History and Examination",
  "version": 1,
  "workflow": {
    "mode": "sectioned",
    "showProgress": true,
    "allowJumpToIncomplete": true
  },
  "followup": {
    "enabled": true,
    "defaultCycleDays": 30,
    "cycleOptionsDays": [7, 14, 30, 60, 90]
  },
  "sections": [
    {
      "id": "visit_context",
      "title": "1. Visit Context",
      "fields": [
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true },
        { "id": "visit_place", "label": "Visit Place", "type": "select", "required": true, "options": ["Field Clinic", "Workplace", "School", "Anganwadi", "Camp", "Home Visit", "OPD"] },
        { "id": "informant", "label": "Informant / Attender", "type": "text", "required": false }
      ]
    },
    {
      "id": "presenting_history",
      "title": "2. Presenting History",
      "fields": [
        {
          "id": "history_items",
          "label": "Presenting complaints - add one by one",
          "type": "repeatable_group",
          "required": true,
          "itemFields": [
            { "id": "complaint", "label": "Complaint", "type": "text" },
            { "id": "history", "label": "History", "type": "textarea" },
            { "id": "duration", "label": "Duration", "type": "text" },
            { "id": "frequency", "label": "Frequency", "type": "text" },
            { "id": "associated_symptoms", "label": "Associated Symptoms", "type": "textarea" }
          ]
        },
        { "id": "hpi_summary", "label": "History of Present Illness Summary", "type": "textarea", "required": true },
        { "id": "red_flags", "label": "Any danger signs", "type": "select", "required": true, "options": ["No", "Yes"] },
        { "id": "red_flag_notes", "label": "Danger sign details", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "past_personal_history",
      "title": "3. Past and Personal History",
      "fields": [
        { "id": "past_history", "label": "Past History", "type": "textarea", "required": false },
        { "id": "personal_history", "label": "Personal History", "type": "textarea", "required": false },
        { "id": "drug_history", "label": "Drug / Treatment History", "type": "textarea", "required": false },
        { "id": "allergy_history", "label": "Allergy History", "type": "textarea", "required": false },
        { "id": "family_history", "label": "Family History", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "clinical_examination",
      "title": "4. Examination",
      "fields": [
        { "id": "general_examination", "label": "General Examination", "type": "textarea", "required": false },
        { "id": "vitals", "label": "Vitals", "type": "textarea", "required": false },
        {
          "id": "system_wise_examination",
          "label": "System wise examination",
          "type": "repeatable_group",
          "required": false,
          "itemFields": [
            { "id": "system", "label": "System", "type": "select", "options": ["CVS", "RS", "CNS", "PA", "ENT", "Skin", "Musculoskeletal", "Obstetric", "Other"] },
            { "id": "findings", "label": "Findings", "type": "textarea" }
          ]
        }
      ]
    },
    {
      "id": "assessment_plan",
      "title": "5. Diagnosis and Plan",
      "fields": [
        { "id": "diagnosis_text", "label": "Diagnosis", "type": "textarea", "required": true },
        { "id": "icd10_code", "label": "ICD-10 Code", "type": "text", "required": false },
        { "id": "investigations", "label": "Investigations", "type": "textarea", "required": false },
        { "id": "rx_treatment", "label": "Rx / Treatment", "type": "textarea", "required": true },
        { "id": "treatment_advice", "label": "Treatment Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false },
        { "id": "follow_up_advice", "label": "Follow-up Advice", "type": "textarea", "required": false }
      ]
    }
  ]
}
