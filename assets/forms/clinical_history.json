{
  "id": "clinical_history",
  "title": "Clinical History (Agenda-Based)",
  "version": 3,
  "workflow": {
    "mode": "sectioned",
    "showProgress": true,
    "allowJumpToIncomplete": true
  },
  "followup": {
    "enabled": true,
    "defaultCycleDays": 30,
    "cycleOptionsDays": [7, 14, 30, 60, 90]
  },
  "sections": [
    {
      "id": "chief_agenda",
      "title": "1. Chief Concern and Agenda",
      "fields": [
        { "id": "chief_complaint", "label": "Chief Complaint (patient words)", "type": "textarea", "required": true, "roles": ["collector", "curator", "doctor", "manager", "creator"] },
        { "id": "duration", "label": "Duration", "type": "text", "required": false },
        { "id": "care_goal", "label": "Patient Goal for this Visit", "type": "text", "required": true, "roles": ["collector", "curator", "doctor", "manager", "creator"] }
      ]
    },
    {
      "id": "targeted_history",
      "title": "2. Targeted History",
      "fields": [
        { "id": "history_present_illness", "label": "History of Present Illness", "type": "textarea", "required": true },
        { "id": "associated_symptoms", "label": "Associated Symptoms", "type": "textarea", "required": false },
        { "id": "red_flag_screen", "label": "Any Danger Signs", "type": "select", "required": true, "options": ["No", "Yes"] },
        { "id": "danger_sign_notes", "label": "Danger Sign Details", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "past_and_drugs",
      "title": "3. Past Illness and Drugs",
      "fields": [
        {
          "id": "known_comorbidities_ncd",
          "label": "Known Comorbidities (NCD) - add one by one",
          "type": "repeatable_group",
          "required": false,
          "itemFields": [
            {
              "id": "disease",
              "label": "Disease",
              "type": "select",
              "options": [
                "Diabetes",
                "Hypertension",
                "CKD",
                "IHD",
                "Stroke",
                "COPD",
                "Asthma",
                "Oral Cancer",
                "Breast Cancer",
                "Cervical Cancer",
                "Other"
              ]
            },
            { "id": "other_disease_name", "label": "If Other, specify disease", "type": "text" },
            { "id": "duration", "label": "Duration", "type": "text" },
            { "id": "on_treatment", "label": "On treatment?", "type": "select", "options": ["No", "Yes"] },
            {
              "id": "medications",
              "label": "Medication details (one by one)",
              "type": "repeatable_group",
              "itemFields": [
                { "id": "name", "label": "Medicine", "type": "text" },
                { "id": "dose", "label": "Dose", "type": "text" },
                { "id": "frequency", "label": "Frequency", "type": "select", "options": ["OD", "BD", "TDS", "QID", "HS", "SOS", "Other"] },
                { "id": "duration", "label": "Duration", "type": "text" }
              ]
            }
          ]
        },
        { "id": "past_illness", "label": "Past Illnesses", "type": "textarea", "required": false },
        { "id": "hospitalizations", "label": "Previous Hospitalizations", "type": "textarea", "required": false },
        { "id": "surgeries", "label": "Past Surgeries", "type": "textarea", "required": false },
        { "id": "current_meds", "label": "Current Medications", "type": "textarea", "required": false },
        { "id": "drug_allergy", "label": "Drug Allergy", "type": "select", "required": true, "options": ["No", "Yes", "Unknown"] },
        { "id": "allergy_details", "label": "Allergy Details", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "lifestyle_context",
      "title": "4. Lifestyle and Context",
      "fields": [
        { "id": "tobacco", "label": "Tobacco Use", "type": "select", "required": false, "options": ["Never", "Former", "Current"] },
        { "id": "alcohol", "label": "Alcohol Use", "type": "select", "required": false, "options": ["Never", "Former", "Current"] },
        { "id": "occupation_risk", "label": "Occupation Exposure Risk", "type": "select", "required": false, "options": ["Low", "Moderate", "High"] },
        { "id": "family_history", "label": "Relevant Family History", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "assessment_plan",
      "title": "5. Clinical Assessment and Plan",
      "fields": [
        { "id": "working_diagnosis", "label": "Working Diagnosis", "type": "textarea", "required": true, "roles": ["doctor", "curator", "manager", "creator"] },
        { "id": "investigations_advised", "label": "Investigations Advised", "type": "textarea", "required": false },
        { "id": "treatment_plan", "label": "Treatment / Advice Plan", "type": "textarea", "required": true, "roles": ["doctor", "curator", "manager", "creator"] },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false },
        { "id": "referral_needed", "label": "Referral Needed", "type": "select", "required": true, "options": ["No", "Yes"], "roles": ["doctor", "curator", "manager", "creator"] },
        { "id": "referral_notes", "label": "Referral Notes", "type": "textarea", "required": false }
      ]
    }
  ]
}
