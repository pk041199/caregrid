{
  "id": "under_5",
  "title": "Under 5 Main Form",
  "version": 1,
  "followup": {
    "enabled": true,
    "defaultCycleDays": 14,
    "cycleOptionsDays": [7, 14, 30]
  },
  "sections": [
    {
      "id": "child_context",
      "title": "1. Child Details",
      "fields": [
        { "id": "visit_date", "label": "Visit Date", "type": "date", "required": true },
        { "id": "age_months", "label": "Age in Months", "type": "number", "required": false },
        { "id": "presenting_complaints", "label": "Presenting Complaints", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "growth_nutrition",
      "title": "2. Growth, Nutrition and Development",
      "fields": [
        { "id": "weight", "label": "Weight", "type": "text", "required": false },
        { "id": "height_length", "label": "Height / Length", "type": "text", "required": false },
        { "id": "nutrition_status", "label": "Nutrition Status", "type": "textarea", "required": false },
        { "id": "developmental_concerns", "label": "Developmental Concerns", "type": "textarea", "required": false },
        { "id": "immunization_status", "label": "Immunization Status", "type": "textarea", "required": false }
      ]
    },
    {
      "id": "child_exam",
      "title": "3. Examination and Plan",
      "fields": [
        { "id": "danger_signs", "label": "Danger Signs", "type": "textarea", "required": false },
        { "id": "examination", "label": "Examination", "type": "textarea", "required": false },
        { "id": "diagnosis_text", "label": "Diagnosis", "type": "textarea", "required": false },
        { "id": "advice", "label": "Advice", "type": "textarea", "required": false },
        { "id": "follow_up_date", "label": "Follow-up Date", "type": "date", "required": false }
      ]
    }
  ]
}
